# Server Configuration
PORT=5000
NODE_ENV=development

# Database Settings
DATABASE_URL=postgres://postgres:password@localhost:5432/dating_app

# Redis Settings (Optional for Socket adapter scaling)
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=your_jwt_signing_key_keep_it_secure

# Error Tracking (Optional)
SENTRY_DSN=

# File Uploads (Cloudinary Settings)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Agora Video/Audio Call Settings
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate
