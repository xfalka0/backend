<?xml version="1.0" encoding="utf-8"?>
<!-- Transparent drawable: replaces the default rn_edit_text_material
     which causes a dark tinted background strip inside TextInput on Android
     when focused or typing. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <solid android:color="@android:color/transparent" />
</shape>
